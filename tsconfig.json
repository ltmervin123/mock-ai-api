{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],

    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    "rootDir": "./src",
    "outDir": "./dist",

    "paths": {
      "@/*": ["./*"]
    }
  },
  "exclude": ["prisma.config.ts", "node_modules"]
}
